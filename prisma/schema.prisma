generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  sessions           Session[]
  facebookCredential FacebookCredential?
  monitoredPages     MonitoredPage[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  auth_type         String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FacebookCredential {
  id                   String   @id @default(cuid())
  userId               String   @unique
  providerAccountId    String   @unique
  encryptedAccessToken String
  encryptedRefreshToken String?
  accessTokenExpiresAt DateTime?
  accessTokenScope     String?
  tokenType            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MonitoredPage {
  id                       String             @id @default(cuid())
  userId                   String
  facebookPageId           String
  name                     String
  category                 String?
  pictureUrl               String?
  encryptedPageAccessToken String?
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncCheckpoint           PageSyncCheckpoint?
  keywordRules             MonitoredKeywordRule[]
  contents                 MonitoredContent[]
  keywordMatches           KeywordMatchEvent[]

  @@unique([userId, facebookPageId])
}

model PageSyncCheckpoint {
  id              String        @id @default(cuid())
  monitoredPageId String        @unique
  afterCursor     String?
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  monitoredPage   MonitoredPage @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
}

model MonitoredKeywordRule {
  id              String        @id @default(cuid())
  monitoredPageId String
  phrase          String
  normalizedPhrase String
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  monitoredPage   MonitoredPage @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  matchEvents     KeywordMatchEvent[]

  @@unique([monitoredPageId, normalizedPhrase])
}

enum MonitoredContentSourceType {
  POST
  COMMENT
}

model MonitoredContent {
  id            String                     @id @default(cuid())
  monitoredPageId String
  sourceType    MonitoredContentSourceType
  sourceId      String
  parentSourceId String?
  contentUrl    String?
  rawText       String?
  normalizedText String
  publishedAt   DateTime?
  fetchedAt     DateTime                   @default(now())
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  monitoredPage MonitoredPage              @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  keywordMatches KeywordMatchEvent[]

  @@unique([monitoredPageId, sourceType, sourceId])
  @@index([monitoredPageId, publishedAt])
}

model KeywordMatchEvent {
  id               String           @id @default(cuid())
  monitoredPageId  String
  keywordRuleId    String
  monitoredContentId String
  matchedPhrase    String
  matchedAt        DateTime         @default(now())
  createdAt        DateTime         @default(now())
  monitoredPage    MonitoredPage    @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)
  keywordRule      MonitoredKeywordRule @relation(fields: [keywordRuleId], references: [id], onDelete: Cascade)
  monitoredContent MonitoredContent @relation(fields: [monitoredContentId], references: [id], onDelete: Cascade)

  @@unique([keywordRuleId, monitoredContentId])
  @@index([monitoredPageId, matchedAt])
}